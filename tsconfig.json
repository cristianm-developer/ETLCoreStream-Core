{
  "compilerOptions": {
    "target": "ESNext",
    "module": "EsNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@schemes/*": ["./src/shared/schemes/*"]
    }    
  },
  "include": ["src/**/*"]
}
