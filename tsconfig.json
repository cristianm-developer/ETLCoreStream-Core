{
  "compilerOptions": {
    "target": "ESNext",
    "module": "EsNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "declaration": true,
    "declarationMap": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@schemes/*": ["./src/shared/schemes/*"],
      "@examples/*": ["./src/examples/*"]
    }
  },
  "include": ["src"]
}
