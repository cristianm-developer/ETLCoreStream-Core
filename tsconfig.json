{
  "compilerOptions": {
    "target": "ESNext",
    "module": "EsNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@core/*": ["./src/core/*"],
      "@shared/*": ["./src/shared/*"],
      "@schemes/*": ["./src/shared/schemes/*"],
      "@examples/*": ["./src/examples/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
